+class FrameAPI(RequestHandler):
+    '''
+    Serves the latest camera image as a single JPEG.
+    '''
+
+    def get(self):
+        if not hasattr(self.application, 'img_arr') or self.application.img_arr is None:
+            self.send_error(503, "camera frame not ready")
+            return
+
+        img = utils.arr_to_binary(self.application.img_arr)
+        self.set_header("Content-Type", "image/jpeg")
+        self.set_header("Content-Length", len(img))
+        self.set_header("Cache-Control", "no-store")
+        self.write(img)
+
+
+class HighResFrameAPI(RequestHandler):
+    '''
+    Serves a highest-resolution still from the active camera.
+    '''
+
+    async def get(self):
+        camera = getattr(self.application, 'camera', None)
+        if camera is None or not hasattr(camera, 'capture_highres_array'):
+            self.send_error(501, reason="high-resolution capture is not available for this camera")
+            return
+
+        try:
+            loop = asyncio.get_running_loop()
+            img_arr = await loop.run_in_executor(None, camera.capture_highres_array)
+        except Exception as e:
+            logger.exception("Unable to capture high-resolution frame")
+            self.send_error(500, reason=str(e))
+            return
+
+        img = utils.arr_to_binary(img_arr)
+        height, width = img_arr.shape[:2]
+        self.set_header("Content-Type", "image/jpeg")
+        self.set_header("Content-Length", len(img))
+        self.set_header("Cache-Control", "no-store")
+        self.set_header("X-Image-Width", width)
+        self.set_header("X-Image-Height", height)
+        self.write(img)
+
