+class AutonomyAPIBase(RequestHandler):
+    def write_json(self, payload: dict, status: int = 200):
+        self.set_status(status)
+        self.set_header("Content-Type", "application/json")
+        self.write(json.dumps(payload, sort_keys=True))
+
+    def read_json_body(self) -> dict:
+        if not self.request.body:
+            return {}
+        return tornado.escape.json_decode(self.request.body)
+
+    def manager(self):
+        manager = getattr(self.application, "autonomy_manager", None)
+        if manager is None:
+            self.write_json(
+                {
+                    "ok": False,
+                    "error": "autonomy runtime is not available",
+                },
+                status=503,
+            )
+            return None
+        return manager
+
+    def status_payload(self) -> dict:
+        manager = getattr(self.application, "autonomy_manager", None)
+        autonomy_status = None if manager is None else manager.status()
+        return {
+            "ok": manager is not None,
+            "drive_mode": getattr(self.application, "mode", None),
+            "autonomy_modes": sorted(AUTONOMY_MODE_TO_DRIVE_MODE.keys()),
+            "drive_mode_map": AUTONOMY_MODE_TO_DRIVE_MODE,
+            "autonomy": autonomy_status,
+        }
+
+
+class AutonomyStatusAPI(AutonomyAPIBase):
+    def get(self):
+        self.write_json(self.status_payload())
+
+
+class AutonomyModeAPI(AutonomyAPIBase):
+    def post(self):
+        data = self.read_json_body()
+        requested = str(data.get("mode", "")).strip()
+        drive_mode = AUTONOMY_MODE_TO_DRIVE_MODE.get(requested)
+        if drive_mode is None:
+            self.write_json(
+                {
+                    "ok": False,
+                    "error": f"unknown autonomy mode {requested!r}",
+                    "valid_modes": sorted(AUTONOMY_MODE_TO_DRIVE_MODE.keys()),
+                },
+                status=400,
+            )
+            return
+
+        self.application.mode = drive_mode
+        self.application.mode_latch = drive_mode
+        if drive_mode == "user" and data.get("stop", True):
+            self.application.angle = 0.0
+            self.application.throttle = 0.0
+
+        payload = self.status_payload()
+        payload["requested_mode"] = requested
+        payload["drive_mode"] = drive_mode
+        self.write_json(payload)
+
+
+class AutonomyEngineAPI(AutonomyAPIBase):
+    def post(self):
+        manager = self.manager()
+        if manager is None:
+            return
+
+        data = self.read_json_body()
+        engine = data.get("engine")
+        if not isinstance(engine, str) or not engine.strip():
+            self.write_json(
+                {
+                    "ok": False,
+                    "error": "engine is required and must be 'module.path:ClassName'",
+                },
+                status=400,
+            )
+            return
+
+        try:
+            status = manager.load_engine(engine.strip(), data.get("config") or {})
+        except EngineLoadError as exc:
+            self.write_json({"ok": False, "error": str(exc), "autonomy": manager.status()}, status=400)
+            return
+
+        self.write_json({"ok": True, "autonomy": status})
+
+
+class AutonomyReloadAPI(AutonomyAPIBase):
+    def post(self):
+        manager = self.manager()
+        if manager is None:
+            return
+
+        try:
+            status = manager.reload_engine()
+        except EngineLoadError as exc:
+            self.write_json({"ok": False, "error": str(exc), "autonomy": manager.status()}, status=400)
+            return
+
+        self.write_json({"ok": True, "autonomy": status})
+
+
