[Unit]
Description=Automa DonkeyCar runtime
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
User=@AUTOMA_USER@
WorkingDirectory=@AUTOMA_PI_HOME@/mycar
Environment=AUTOMA_PI_HOME=@AUTOMA_PI_HOME@
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-@AUTOMA_PI_HOME@/.config/automa/donkey.env
ExecStart=@AUTOMA_PI_HOME@/mycar/automa_drive.sh
Restart=always
RestartSec=3
TimeoutStopSec=20
KillSignal=SIGINT
StandardOutput=journal
StandardError=journal
SyslogIdentifier=automa-donkey

[Install]
WantedBy=multi-user.target
